  "keyFeatures": [
    "Voice-first interface with push-to-talk hotkey",
    "Instant interruptions with barge-in support",
    "Full terminal transparency for all operations",
    "Multi-session support with concurrent workflows",
    "Integrated Pi coding agent for tool execution",
    "Unix socket-based daemon architecture",
    "Streaming tool output and real-time updates",
    "Background task execution with notifications"
  ],
  "publicApiSurface": [
    "duck [path] - Attach workspace and stream events",
    "duck say <message> - Send typed message to session",
    "duck sessions [--all] - List active sessions",
    "duck doctor - Check system health",
    "DaemonClient - Unix socket NDJSON client",
    "createRenderer() - Factory for text/JSON renderers",
    "voice_tool_call - Execute tools from voice interface",
    "voice_connect - Establish voice session",
    "voice_state - Query voice session state",
    "attach - Attach workspace to daemon",
    "follow - Stream session events",
    "extension_ui_response - Handle UI prompts"
  ]
